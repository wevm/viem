{"code":"import { Account, WebCryptoP256 } from 'viem/tempo'\nimport { client } from './viem.config'\n\n// 1. Instantiate account.\nconst account = Account.fromSecp256k1('0x...')\n\n// 2. Generate a non-extractable WebCrypto key pair & instantiate access key.\nconst keyPair = await WebCryptoP256.createKeyPair()\nconst accessKey = Account.fromWebCryptoP256(keyPair, {\n  access: account,\n})\n\n// 3. Sign over key authorization with account.\nconst keyAuthorization = await account.signKeyAuthorization(accessKey)\n\n// 4. Attach key authorization to (next) transaction.\nconst receipt = await client.sendTransactionSync({\n  account: accessKey, // sign transaction with access key // [!code hl]\n  data: '0xdeadbeef0000000000000000000000000000000001',\n  keyAuthorization, // [!code hl]\n  to: '0xcafebabecafebabecafebabecafebabecafebabe',\n})","nodes":[{"type":"hover","text":"import Account","start":9,"length":7,"target":"Account","line":0,"character":9},{"type":"hover","text":"import WebCryptoP256","start":18,"length":13,"target":"WebCryptoP256","line":0,"character":18},{"type":"hover","text":"(alias) const client: any\nimport client","start":61,"length":6,"target":"client","line":1,"character":9},{"type":"hover","text":"const account: any","start":125,"length":7,"target":"account","line":4,"character":6},{"type":"hover","text":"import Account","start":135,"length":7,"target":"Account","line":4,"character":16},{"type":"hover","text":"any","start":143,"length":13,"target":"fromSecp256k1","line":4,"character":24},{"type":"hover","text":"const keyPair: any","start":251,"length":7,"target":"keyPair","line":7,"character":6},{"type":"hover","text":"import WebCryptoP256","start":267,"length":13,"target":"WebCryptoP256","line":7,"character":22},{"type":"hover","text":"any","start":281,"length":13,"target":"createKeyPair","line":7,"character":36},{"type":"hover","text":"const accessKey: any","start":303,"length":9,"target":"accessKey","line":8,"character":6},{"type":"hover","text":