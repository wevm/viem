{"code":"import { Account, WebCryptoP256 } from 'viem/tempo'\nimport { client } from './viem.config'\n\n// Create root account\nconst account = Account.fromSecp256k1(\n  '0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80'\n)\n\n// Create access key \nconst keyPair = await WebCryptoP256.createKeyPair()\nconst accessKey = Account.fromWebCryptoP256(keyPair, { access: account })\n\n// Sign a key authorization\nconst keyAuthorization = await account.signKeyAuthorization(accessKey, {\n  expiry: Math.floor(Date.now() / 1000) + 86400, // 24 hour expiry\n})\n\n// Attach to next transaction\nconst receipt = await client.sendTransactionSync({\n  account: accessKey,\n  keyAuthorization,\n  to: '0xdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef',\n})\n\n// Now any subsequent transaction can be used with `accessKey`\n// WITHOUT the `keyAuthorization` parameter!","nodes":[{"type":"hover","text":"import Account","start":9,"length":7,"target":"Account","line":0,"character":9},{"type":"hover","text":"import WebCryptoP256","start":18,"length":13,"target":"WebCryptoP256","line":0,"character":18},{"type":"hover","text":"(alias) const client: any\nimport client","start":61,"length":6,"target":"client","line":1,"character":9},{"type":"hover","text":"const account: any","start":121,"length":7,"target":"account","line":4,"character":6},{"type":"hover","text":"import Account","start":131,"length":7,"target":"Account","line":4,"character":16},{"type":"hover","text":"any","start":139,"length":13,"target":"fromSecp256k1","line":4,"character":24},{"type":"hover","text":"const keyPair: any","start":256,"length":7,"target":"keyPair","line":9,"character":6},{"type":"hover","text":"import WebCryptoP256","start":272,"length":13,"target":"WebCryptoP256","line":9,"character":22},{"type":"hover","text":"any","start":286,"length":13,"target":"createKeyPair","line":9,"character":36},{"type":"hover","text":"const accessKey: any","start":308,"length":9,"target":"accessKey","line":10,"character":6}