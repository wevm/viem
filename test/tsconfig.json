{
  "extends": "../tsconfig.base.json",
  "exclude": [
    "./tempo"
  ],
  "include": [
    ".",
    "../src",
    "../contracts/generated.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "types": [
      "node"
    ],
    "paths": {
      "~contracts/*": [
        "../contracts/*"
      ],
      "~test/*": [
        "./src/*"
      ],
      "viem": [
        "../src/index.ts"
      ],
      "viem/chains": [
        "../src/chains/index.ts"
      ],
      "viem/node": [
        "../src/node/index.ts"
      ],
      "viem/tokens": [
        "../src/tokens/index.ts"
      ],
      "viem/utils": [
        "../src/utils/index.ts"
      ],
      "viem/zod": [
        "../src/zod/index.ts"
      ]
    }
  }
}
