{
  "private": true,
  "scripts": {
    "build": "pnpm exports:update && zile && cp -R src/trusted-setups dist/",
    "changeset:prepublish": "pnpm version:update && pnpm build && zile publish:prepare",
    "changeset:publish": "pnpm changeset:prepublish && changeset publish && zile publish:post",
    "changeset:version": "pnpm install --lockfile-only && changeset version && pnpm version:update && pnpm check",
    "check": "vp check --fix",
    "check:repo": "sherif -r root-package-dependencies",
    "check:types": "tsc -b",
    "contracts:build": "forge build --config-path ./contracts/foundry.toml && bun scripts/contracts:build.ts",
    "deps": "pnpx taze -r",
    "dev": "pnpm exports:update && zile dev",
    "docs:build": "pnpm docs:sync-utils && pnpm --filter site build",
    "docs:dev": "pnpm docs:sync-utils --if-needed && pnpm --filter site dev",
    "docs:sync-utils": "bun scripts/docs:sync-utils.ts",
    "exports:update": "bun scripts/exports:update.ts",
    "gen:tempo-abis": "bun scripts/gen:tempo-abis.ts",
    "gen:tokenlist": "bun scripts/gen:tokenlist.ts && vp check --fix src/tokens",
    "knip": "knip --production --no-tag-hints",
    "postinstall": "git submodule update --init --recursive && pnpm contracts:build && pnpm dev",
    "preinstall": "pnpx only-allow pnpm",
    "prepare": "pnpm simple-git-hooks",
    "size": "size-limit",
    "test": "vp test",
    "test:build": "publint --strict . && attw --pack . --profile esm-only",
    "test:env": "pnpm test:env:bun && pnpm test:env:next && pnpm test:env:node && pnpm test:env:tsc && pnpm test:env:vite",
    "test:env:bun": "pnpm --filter test-bun test",
    "test:env:next": "pnpm --filter test-next test",
    "test:env:node": "pnpm --filter test-node test",
    "test:env:tsc": "pnpm --filter test-tsc test",
    "test:env:vite": "pnpm --filter test-vite test",
    "test:typecheck": "SKIP_GLOBAL_SETUP=true vp test --typecheck.only",
    "version:update": "bun scripts/version:update.ts"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@paulmillr/trusted-setups": "catalog:",
    "@pimlico/alto": "catalog:",
    "@remix-run/node-fetch-server": "catalog:",
    "@size-limit/preset-big-lib": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "bun": "catalog:",
    "knip": "catalog:",
    "micro-eth-signer": "catalog:",
    "permissionless": "catalog:",
    "prool": "catalog:",
    "publint": "catalog:",
    "sherif": "catalog:",
    "simple-git-hooks": "catalog:",
    "size-limit": "catalog:",
    "testcontainers": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vp": "catalog:",
    "zile": "catalog:"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check"
  },
  "knip": {
    "ignore": [
      ".github/**",
      "contracts-old/**",
      "environments/**",
      "src-old/**",
      "src/vendor/**",
      "test-old/**",
      "src/core/internal/**"
    ],
    "ignoreBinaries": [
      "dev",
      "forge",
      "only-allow",
      "printf"
    ],
    "ignoreDependencies": [
      "bun",
      "@size-limit/preset-big-lib",
      "abitype"
    ],
    "ignoreWorkspaces": [
      "test"
    ],
    "vitest": {
      "config": [
        "vite.config.ts"
      ],
      "entry": [
        "**/*.{test,test-d,spec}.?(c|m)[jt]s?(x)"
      ]
    },
    "workspaces": {
      ".": {
        "entry": [
          "src/index.ts!",
          "src/node/index.ts!",
          "src/utils/index.ts!"
        ],
        "project": [
          "src/**/*.ts!",
          "scripts/*.ts"
        ]
      },
      "site": {
        "project": [
          "**/*.ts",
          "**/*.tsx"
        ]
      }
    }
  },
  "size-limit": [
    {
      "name": "import * from 'viem' (esm)",
      "path": "./dist/index.js",
      "limit": "70 kB",
      "import": "*"
    }
  ],
  "pnpm": {
    "overrides": {
      "typescript": "^5.9.3",
      "@opentelemetry/api@^1.8.0": "~1.7.0",
      "permissionless>viem": "workspace:*",
      "@babel/helpers@<7.26.10": "7.26.10",
      "@babel/runtime@<7.26.10": "7.26.10",
      "@hono/node-server@<1.19.13": "1.19.13",
      "@isaacs/brace-expansion@<=5.0.0": "5.0.1",
      "@modelcontextprotocol/sdk@>=1.10.0 <=1.25.3": "1.26.0",
      "ajv@<8.18.0": "8.18.0",
      "brace-expansion@>=2.0.0 <=2.0.1": "2.0.2",
      "cookie@<0.7.0": "^0.7.0",
      "cross-spawn@<6.0.6": ">=6.0.6",
      "cross-spawn@>=7.0.0 <7.0.5": ">=7.0.5",
      "estree-util-value-to-estree@<3.3.3": "3.3.3",
      "express-rate-limit@>=8.2.0 <8.2.2": ">=8.2.2",
      "fastify": ">=5.8.5",
      "follow-redirects@<1.16.0": "1.16.0",
      "uuid@<14.0.0": "14.0.0",
      "postcss@<8.5.10": "8.5.10",
      "protobufjs@<=7.5.7": "7.5.8",
      "protobufjs@>=8.0.0 <8.2.0": "8.2.0",
      "@protobufjs/utf8@<=1.1.0": "1.1.1",
      "@opentelemetry/sdk-node@<0.217.0": "0.217.0",
      "find-my-way@>=5.5.0 <8.2.2": "^8.2.2",
      "glob@>=10.3.7 <=11.0.3": ">=11.1.0",
      "hono": ">=4.12.16",
      "ip-address@<=10.1.0": "10.1.1",
      "lodash@>=4.0.0 <=4.17.23": "4.18.1",
      "lodash-es@>=4.0.0 <=4.17.22": "4.17.23",
      "mdast-util-to-hast@>=13.0.0 <13.2.1": "13.2.1",
      "micromatch@<4.0.8": "^4.0.8",
      "minimatch": ">=10.2.3",
      "nanoid@>=4.0.0 <5.0.9": "5.0.9",
      "next@>=15.6.0-canary.0 <16.1.5": ">=16.1.5",
      "next@>=16.0.0-beta.0 <16.1.5": ">=16.1.5",
      "on-headers@<1.1.0": "1.1.0",
      "qs@>=6.11.1 <=6.15.1": "6.15.2",
      "react-router@>=7.0.0 <=7.11.0": "7.12.0",
      "react-server-dom-webpack@>=19.2.0-canary-63779030-20250328 <19.2.4": "19.2.4",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "send@<0.19.0": "^0.19.0",
      "serialize-javascript@<7.0.5": "7.0.5",
      "serve-static@<1.16.0": "^1.16.0",
      "smol-toml@<1.6.1": "1.6.1",
      "tar": ">=7.5.10",
      "tar-fs@>=3.0.0 <3.1.1": ">=3.1.1",
      "tmp@<0.2.6": "0.2.6",
      "undici@>=7.0.0 <7.24.0": "7.24.0",
      "vite@>=6.0.0 <=6.4.1": "6.4.2",
      "vite@>=7.0.0 <=7.3.1": "7.3.2",
      "webpack@>=5.49.0 <=5.104.0": "5.104.1",
      "ws@>=7.0.0 <7.5.10": "^7.5.10",
      "ws@>=8.0.0 <8.20.1": "^8.20.1",
      "yauzl@<3.2.1": "3.2.1",
      "next@>=16.0.1 <16.1.7": "16.1.7",
      "next@>=16.0.0-beta.0 <16.1.7": "16.1.7",
      "next@>=10.0.0 <16.1.7": "16.1.7",
      "path-to-regexp@>=8.0.0 <8.4.0": "8.4.0",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "srvx@<0.11.13": "0.11.13",
      "brace-expansion@>=4.0.0 <5.0.6": "5.0.6",
      "yaml@>=2.0.0 <2.8.3": "2.8.3",
      "@vitejs/plugin-rsc@<=0.5.25": "0.5.26",
      "next@>=16.0.0-beta.0 <16.2.6": "16.2.6",
      "react-server-dom-webpack@>=19.2.0 <19.2.6": "19.2.6",
      "basic-ftp@<=5.3.0": "5.3.1",
      "fast-uri@<=3.1.1": "3.1.2"
    },
    "onlyBuiltDependencies": [
      "bun",
      "protobufjs",
      "simple-git-hooks"
    ],
    "patchedDependencies": {
      "vocs@2.0.14": "patches/vocs@2.0.14.patch"
    }
  },
  "[!start-pkg]": "",
  "name": "viem",
  "description": "TypeScript Interface for Ethereum",
  "version": "2.52.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "homepage": "https://viem.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/wevm/viem.git"
  },
  "bugs": {
    "url": "https://github.com/wevm/viem/issues"
  },
  "authors": [
    "awkweb.eth",
    "jxom.eth"
  ],
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/wevm"
    }
  ],
  "keywords": [
    "eth",
    "ethereum",
    "dapps",
    "wallet",
    "web3",
    "typescript"
  ],
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.ts.snap",
    "!src/**/*.test-d.ts",
    "!src/**/*.tsbuildinfo",
    "!src/tsconfig.json"
  ],
  "peerDependencies": {
    "typescript": ">=5.0.4"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "abitype": "1.2.3",
    "ox": "1.0.0-beta.11"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "src": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./chains": {
      "types": "./dist/chains/index.d.ts",
      "src": "./src/chains/index.ts",
      "default": "./dist/chains/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "src": "./src/node/index.ts",
      "default": "./dist/node/index.js"
    },
    "./tempo": {
      "types": "./dist/tempo/index.d.ts",
      "src": "./src/tempo/index.ts",
      "default": "./dist/tempo/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "src": "./src/tokens/index.ts",
      "default": "./dist/tokens/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "src": "./src/utils/index.ts",
      "default": "./dist/utils/index.js"
    },
    "./zod": {
      "types": "./dist/zod/index.d.ts",
      "src": "./src/zod/index.ts",
      "default": "./dist/zod/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/*/index.d.ts"
      ]
    }
  }
}
