    "ethereum",
    "dapps",
    "wallet",
    "web3",
    "typescript"
  ],
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.ts.snap",
    "!src/**/*.test-d.ts",
    "!src/**/*.tsbuildinfo",
    "!src/tsconfig.json"
  ],
