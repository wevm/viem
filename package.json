{
  "private": true,
  "scripts": {
    "build": "pnpm exports:update && zile && cp -R src/trusted-setups dist/",
    "changeset:prepublish": "pnpm version:update && pnpm build && zile publish:prepare",
    "changeset:publish": "pnpm changeset:prepublish && changeset publish && zile publish:post",
    "changeset:version": "pnpm install --lockfile-only && changeset version && pnpm version:update && pnpm check",
    "check": "biome check --write --unsafe",
    "check:repo": "sherif -r root-package-dependencies",
    "check:types": "tsc -b",
    "contracts:build": "forge build --config-path ./contracts/foundry.toml && bun scripts/contracts:build.ts",
    "deps": "pnpx taze -r",
    "dev": "pnpm exports:update && zile dev",
    "docs:build": "pnpm --filter site build",
    "docs:dev": "pnpm --filter site dev",
    "exports:update": "bun scripts/exports:update.ts",
    "gen:tempo-abis": "bun scripts/gen:tempo-abis.ts",
    "knip": "knip --production --no-tag-hints",
    "postinstall": "git submodule update --init --recursive && pnpm contracts:build && pnpm dev",
    "preinstall": "pnpx only-allow pnpm",
    "prepare": "pnpm simple-git-hooks",
    "size": "size-limit",
    "test": "vitest -c ./test/vitest.config.ts",
    "test:build": "publint --strict . && attw --pack . --profile esm-only",
    "test:chains": "vitest test/scripts/chains.test.ts",
    "test:env": "pnpm test:env:bun && pnpm test:env:next && pnpm test:env:node && pnpm test:env:tsc && pnpm test:env:vite",
    "test:env:bun": "pnpm --filter test-bun test",
    "test:env:next": "pnpm --filter test-next test",
    "test:env:node": "pnpm --filter test-node test",
    "test:env:tsc": "pnpm --filter test-tsc test",
    "test:env:vite": "pnpm --filter test-vite test",
    "test:typecheck": "SKIP_GLOBAL_SETUP=true vitest --typecheck.only -c ./test/vitest.config.ts",
    "vectors": "bun test vectors/**/*.test.ts",
    "vectors:generate": "bun vectors/generate.ts",
    "version:update": "bun scripts/version:update.ts"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@biomejs/biome": "catalog:",
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@paulmillr/trusted-setups": "catalog:",
    "@pimlico/alto": "catalog:",
    "@remix-run/node-fetch-server": "catalog:",
    "@size-limit/preset-big-lib": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "bun": "catalog:",
    "knip": "catalog:",
    "micro-eth-signer": "catalog:",
    "permissionless": "catalog:",
    "prool": "catalog:",
    "publint": "catalog:",
    "sherif": "catalog:",
    "simple-git-hooks": "catalog:",
    "size-limit": "catalog:",
    "testcontainers": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zile": "catalog:"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check"
  },
  "knip": {
    "ignore": [
      ".github/**",
      "environments/**",
      "vectors/**"
    ],
    "ignoreBinaries": [
      "dev",
      "forge",
      "only-allow",
      "printf"
    ],
    "ignoreDependencies": [
      "bun",
      "@size-limit/preset-big-lib"
    ],
    "ignoreWorkspaces": [
      "test"
    ],
    "vitest": {
      "config": [
        "test/vitest.config.ts"
      ],
      "entry": [
        "**/*.{test,test-d,spec}.?(c|m)[jt]s?(x)"
      ]
    },
    "workspaces": {
      ".": {
        "entry": [
          "src/index.ts!",
          "src/{account-abstraction,accounts,actions,celo,chains,ens,experimental,experimental/erc7739,experimental/erc7821,experimental/erc7811,experimental/erc7846,experimental/erc7895,linea,node,nonce,op-stack,siwe,tempo,tempo/actions,tempo/chains,tempo/zones,utils,window,zksync}/index.ts!",
          "src/chains/utils.ts!"
        ],
        "project": [
          "src/**/*.ts!",
          "scripts/*.ts"
        ]
      },
      "site": {
        "project": [
          "**/*.ts",
          "**/*.tsx"
        ]
      }
    }
  },
  "size-limit": [
    {
      "name": "import * from 'viem' (esm)",
      "path": "./dist/index.js",
      "limit": "85 kB",
      "import": "*"
    },
    {
      "name": "import { createClient, http } from 'viem'",
      "path": "./dist/index.js",
      "limit": "6.6 kB",
      "import": "{ createClient, http }"
    },
    {
      "name": "import * from 'viem/account-abstraction'",
      "path": "./dist/account-abstraction/index.js",
      "limit": "61 kB",
      "import": "*"
    },
    {
      "name": "import * from 'viem/accounts'",
      "path": "./dist/accounts/index.js",
      "limit": "97 kB",
      "import": "*"
    },
    {
      "name": "import { privateKeyToAccount } from 'viem/accounts'",
      "path": "./dist/accounts/index.js",
      "limit": "22 kB",
      "import": "{ privateKeyToAccount }"
    },
    {
      "name": "import { mnemonicToAccount } from 'viem/accounts'",
      "path": "./dist/accounts/index.js",
      "limit": "30 kB",
      "import": "{ mnemonicToAccount }"
    },
    {
      "name": "import * from 'viem/actions'",
      "path": "./dist/actions/index.js",
      "limit": "69 kB",
      "import": "*"
    },
    {
      "name": "import { getBlockNumber } from 'viem/actions'",
      "path": "./dist/actions/index.js",
      "limit": "1 kB",
      "import": "{ getBlockNumber }"
    },
    {
      "name": "import * from 'viem/chains'",
      "path": "./dist/chains/index.js",
      "limit": "110 kB",
      "import": "*"
    },
    {
      "name": "import { mainnet } from 'viem/chains'",
      "path": "./dist/chains/index.js",
      "limit": "500 B",
      "import": "{ mainnet }"
    },
    {
      "name": "import { tempoTestnet } from 'viem/chains'",
      "path": "./dist/chains/index.js",
      "limit": "67 kB",
      "import": "{ tempoTestnet }"
    },
    {
      "name": "import * from 'viem/chains/utils'",
      "path": "./dist/chains/utils.js",
      "limit": "8 kB",
      "import": "*"
    },
    {
      "name": "import * from 'viem/ens'",
      "path": "./dist/ens/index.js",
      "limit": "53 kB",
      "import": "*"
    },
    {
      "name": "import { getEnsAvatar } from 'viem/ens'",
      "path": "./dist/ens/index.js",
      "limit": "28 kB",
      "import": "{ getEnsAvatar }"
    },
    {
      "name": "import * from 'viem/siwe'",
      "path": "./dist/siwe/index.js",
      "limit": "49 kB",
      "import": "*"
    },
    {
      "name": "import { verifySiweMessage } from 'viem/siwe'",
      "path": "./dist/siwe/index.js",
      "limit": "48 kB",
      "import": "{ verifySiweMessage }"
    },
    {
      "name": "import { verifyHash } from 'viem/actions'",
      "path": "./dist/actions/index.js",
      "limit": "47 kB",
      "import": "{ verifyHash }"
    }
  ],
