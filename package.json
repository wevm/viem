{
  "scripts": {
    "build": "pnpm exports:update && zile",
    "changeset:prepublish": "pnpm version:update && pnpm build",
    "changeset:publish": "zile publish:prepare && changeset publish && zile publish:post",
    "changeset:version": "pnpm install --lockfile-only && changeset version && pnpm version:update && pnpm check",
    "clean": "rm -rf dist *.tsbuildinfo src/*.tsbuildinfo src/_esm src/_cjs src/_types",
    "contracts:build": "forge build --config-path ./contracts/foundry.toml && bun scripts/generateTypedArtifacts.ts",
    "docs:dev": "pnpm --filter site dev",
    "docs:build": "pnpm --filter site build",
    "check": "vp check --fix",
    "check:ci": "vp check",
    "check:types": "tsc -b",
    "check:unused": "knip --production",
    "exports:update": "node --import tsx ./scripts/exports:update.ts",
    "gen:tempo-abis": "bun scripts/generateTempoAbis.ts",
    "postinstall": "git submodule update --init --recursive && pnpm contracts:build",
    "preconstruct": "pnpm dev",
    "preinstall": "pnpx only-allow pnpm",
    "prepare": "pnpm simple-git-hooks",
    "dev": "pnpm exports:update && zile dev",
    "format": "vp fmt",
    "lint": "vp lint",
    "size": "size-limit",
    "test": "vp test",
    "test:coverage": "vp test run --coverage",
    "test:typecheck": "SKIP_GLOBAL_SETUP=true vp test --typecheck.only",
    "vectors": "bun test vectors/**/*.test.ts",
    "vectors:generate": "bun vectors/generate.ts",
    "version:update": "bun scripts/updateVersion.ts"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.4.8",
    "@changesets/cli": "^2.29.7",
    "@paulmillr/trusted-setups": "^0.1.2",
    "@pimlico/alto": "0.0.18",
    "@size-limit/preset-big-lib": "^11.2.0",
    "@types/bun": "^1.2.22",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "4.1.5",
    "@voidzero-dev/vite-plus-core": "0.1.21",
    "bun": "^1.2.22",
    "knip": "^5.64.0",
    "micro-eth-signer": "^0.14.0",
    "permissionless": "^0.2.57",
    "prool": "~0.2.3",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^11.2.0",
    "testcontainers": "^11.10.0",
    "tsx": "^4.17.0",
    "typescript": "catalog:",
    "vp": "npm:vite-plus@0.1.21",
    "zile": "^0.0.25"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check"
  },
  "knip": {
    "ignore": [
      ".github/**",
      "scripts-old/**",
      "vectors/**",
      "dist/**"
    ],
    "ignoreBinaries": [
      "dev",
      "forge",
      "only-allow",
      "printf"
    ],
    "ignoreDependencies": [
      "@noble/curves",
      "@noble/hashes",
      "@scure/bip32",
      "@scure/bip39",
      "bun",
      "@size-limit/preset-big-lib",
      "abitype",
      "isows",
      "ws"
    ],
    "ignoreWorkspaces": [],
    "vitest": false,
    "workspaces": {
      ".": {
        "project": [
          "scripts/*.ts"
        ],
        "entry": [
          "src/index.ts!",
          "src/{account-abstraction,accounts,actions,celo,chains,ens,experimental,experimental/erc7739,experimental/erc7821,experimental/erc7811,experimental/erc7846,experimental/erc7895,linea,node,nonce,op-stack,siwe,tempo,tempo/actions,tempo/zones,utils,window,zksync}/index.ts!",
          "src/chains/utils.ts!"
        ],
        "ignore": [
          "src/node/trustedSetups_cjs.ts"
        ]
      },
      "site": {
        "project": [
          "**/*.ts",
          "**/*.tsx"
        ]
      }
    }
  },
  "size-limit": [
    {
      "name": "import * from 'viem/utils'",
      "path": "./dist/utils/index.js",
      "limit": "100 kB",
      "import": "*"
    },
    {
      "name": "import * from 'viem/utils/Bytes'",
      "path": "./dist/utils/Bytes.js",
      "limit": "100 kB",
      "import": "*"
    },
    {
      "name": "import * from 'viem/utils/Hex'",
      "path": "./dist/utils/Hex.js",
      "limit": "100 kB",
      "import": "*"
    },
    {
      "name": "import * from 'viem/utils/Value'",
      "path": "./dist/utils/Value.js",
      "limit": "100 kB",
      "import": "*"
    }
  ],
