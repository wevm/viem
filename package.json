{
  "private": true,
  "scripts": {
    "bench:types": "TYPES=true vp test --run --project type-bench",
    "build": "pnpm exports:update && zile",
    "changeset:prepublish": "pnpm version:update && pnpm build && zile publish:prepare",
    "changeset:publish": "pnpm changeset:prepublish && changeset publish && zile publish:post",
    "changeset:version": "pnpm install --lockfile-only && changeset version && pnpm version:update && pnpm check",
    "check": "vp check --fix",
    "check:repo": "sherif -r root-package-dependencies",
    "check:types": "tsc -b",
    "contracts:build": "forge build --config-path ./contracts/foundry.toml && bun scripts/contracts:build.ts",
    "deps": "pnpx taze -r",
    "dev": "pnpm exports:update && zile dev",
    "docs:build": "pnpm docs:sync-utils && pnpm --filter site build",
    "docs:dev": "pnpm docs:sync-utils --if-needed && pnpm --filter site dev",
    "docs:sync-utils": "bun scripts/docs:sync-utils.ts",
    "exports:update": "bun scripts/exports:update.ts",
    "gen:tempo-abis": "bun scripts/gen:tempo-abis.ts",
    "gen:tempo-earn-abis": "bun scripts/generateTempoEarnAbis.ts && vp fmt src/tempo/Abis.ts test/src/tempo/earnContracts.ts",
    "gen:tokenlist": "bun scripts/gen:tokenlist.ts && vp check --fix src/tokens",
    "knip": "knip --production --no-tag-hints",
    "postinstall": "pnpm dev",
    "preinstall": "pnpx only-allow pnpm",
    "prepare": "pnpm simple-git-hooks",
    "size": "size-limit",
    "sync:tempo-abis": "bun scripts/gen:tempo-abis.ts --sync",
    "test": "vp test",
    "test:build": "publint --strict . && attw --pack . --profile esm-only",
    "test:env": "pnpm test:env:bun && pnpm test:env:next && pnpm test:env:node && pnpm test:env:tsc && pnpm test:env:vite",
    "test:env:bun": "pnpm --filter test-bun test",
    "test:env:next": "pnpm --filter test-next test",
    "test:env:node": "pnpm --filter test-node test",
    "test:env:tsc": "pnpm --filter test-tsc test",
    "test:env:vite": "pnpm --filter test-vite test",
    "test:typecheck": "OFFLINE=true vp test --typecheck.only",
    "version:update": "bun scripts/version:update.ts"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@ark/attest": "catalog:",
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@openzeppelin/contracts": "catalog:",
    "@paulmillr/trusted-setups": "catalog:",
    "@pimlico/alto": "catalog:",
    "@pimlico/alto-v09": "catalog:",
    "@remix-run/node-fetch-server": "catalog:",
    "@size-limit/preset-big-lib": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "account-abstraction-v07": "catalog:",
    "account-abstraction-v08": "catalog:",
    "bun": "catalog:",
    "knip": "catalog:",
    "micro-eth-signer": "catalog:",
    "permissionless": "catalog:",
    "prool": "catalog:",
    "publint": "catalog:",
    "sherif": "catalog:",
    "simple-git-hooks": "catalog:",
    "size-limit": "catalog:",
    "solady-v153": "catalog:",
    "solady-v288": "catalog:",
    "testcontainers": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vp": "catalog:",
    "zile": "catalog:"
  },
  "packageManager": "pnpm@11.15.0",
  "engines": {
    "node": ">=24.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check"
  },
  "knip": {
    "ignoreExportsUsedInFile": true,
    "ignore": [
      ".github/**",
      "environments/**",
      "src/vendor/**",
      "src/core/internal/**",
      "src/op-stack/actions/l1/testFixtures.ts"
    ],
    "ignoreBinaries": [
      "dev",
      "forge",
      "only-allow",
      "printf"
    ],
    "ignoreDependencies": [
      "bun",
      "@size-limit/preset-big-lib",
      "@openzeppelin/contracts",
      "abitype",
      "account-abstraction-v07",
      "account-abstraction-v08",
      "solady-v153",
      "solady-v288"
    ],
    "ignoreWorkspaces": [
      "test"
    ],
    "vitest": {
      "config": [
        "vite.config.ts"
      ],
      "entry": [
        "**/*.{bench-d,test,test-d,spec}.?(c|m)[jt]s?(x)"
      ]
    },
    "workspaces": {
      ".": {
        "entry": [
          "src/index.ts!",
          "src/node/index.ts!",
          "src/utils/index.ts!"
        ],
        "project": [
          "src/**/*.ts!",
          "scripts/*.ts"
        ]
      },
      "site": {
        "project": [
          "**/*.ts",
          "**/*.tsx"
        ]
      }
    }
  },
  "size-limit": [
    {
      "name": "import * from 'viem' (esm)",
      "path": "./dist/index.js",
      "limit": "95 kB",
      "import": "*"
    },
    {
      "name": "import { Actions } from 'viem'",
      "path": "./dist/index.js",
      "limit": "78.5 kB",
      "import": "{ Actions }"
    },
    {
      "name": "import { Client } from 'viem'",
      "path": "./dist/index.js",
      "limit": "18.5 kB",
      "import": "{ Client }"
    },
    {
      "name": "import * from 'viem/chains'",
      "path": "./dist/chains/index.js",
      "limit": "93.5 kB",
      "import": "*"
    },
    {
      "name": "import { mainnet } from 'viem/chains'",
      "path": "./dist/chains/index.js",
      "limit": "850 B",
      "import": "{ mainnet }"
    },
    {
      "name": "import * from 'viem/erc4337'",
      "path": "./dist/erc4337/index.js",
      "limit": "75.5 kB",
      "import": "*"
    },
    {
      "name": "import * from 'viem/node'",
      "path": "./dist/node/index.js",
      "limit": "5.5 kB",
      "import": "*",
      "ignore": [
        "node:net",
        "node:path",
        "node:url"
      ]
    },
    {
      "name": "import * from 'viem/op-stack'",
      "path": "./dist/op-stack/index.js",
      "limit": "67.5 kB",
      "import": "*"
    },
    {
      "name": "import * from 'viem/tempo'",
      "path": "./dist/tempo/index.js",
      "limit": "129.5 kB",
      "import": "*"
    },
    {
      "name": "import * from 'viem/tokens'",
      "path": "./dist/tokens/index.js",
      "limit": "4.2 kB",
      "import": "*"
    },
    {
      "name": "import * from 'viem/utils'",
      "path": "./dist/utils/index.js",
      "limit": "167 kB",
      "import": "*"
    },
    {
      "name": "import * from 'viem/window'",
      "path": "./dist/window/index.js",
      "limit": "90 B",
      "import": "*"
    },
    {
      "name": "import * from 'viem/zod'",
      "path": "./dist/zod/index.js",
      "limit": "96 kB",
      "import": "*"
    }
  ],
  "[!start-pkg]": "",
  "name": "viem",
  "description": "TypeScript Interface for Ethereum",
  "version": "2.52.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "homepage": "https://viem.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/wevm/viem.git"
  },
  "bugs": {
    "url": "https://github.com/wevm/viem/issues"
  },
  "authors": [
    "awkweb.eth",
    "jxom.eth"
  ],
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/wevm"
    }
  ],
  "keywords": [
    "eth",
    "ethereum",
    "dapps",
    "wallet",
    "web3",
    "typescript"
  ],
  "files": [
    "dist",
    "src",
    "!src/**/*.bench-d.ts",
    "!src/**/*.test.ts",
    "!src/**/*.test.ts.snap",
    "!src/**/*.test-d.ts",
    "!src/**/*.tsbuildinfo",
    "!src/tsconfig.json"
  ],
  "peerDependencies": {
    "typescript": ">=5.9.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "abitype": "1.3.0",
    "ox": "1.0.4"
  },
  "exports": {
    ".": {
      "src": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./chains": {
      "src": "./src/chains/index.ts",
      "types": "./dist/chains/index.d.ts",
      "default": "./dist/chains/index.js"
    },
    "./erc4337": {
      "src": "./src/erc4337/index.ts",
      "types": "./dist/erc4337/index.d.ts",
      "default": "./dist/erc4337/index.js"
    },
    "./node": {
      "src": "./src/node/index.ts",
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./op-stack": {
      "src": "./src/op-stack/index.ts",
      "types": "./dist/op-stack/index.d.ts",
      "default": "./dist/op-stack/index.js"
    },
    "./tempo": {
      "src": "./src/tempo/index.ts",
      "types": "./dist/tempo/index.d.ts",
      "default": "./dist/tempo/index.js"
    },
    "./tempo/actions": {
      "src": "./src/tempo/actions/index.ts",
      "types": "./dist/tempo/actions/index.d.ts",
      "default": "./dist/tempo/actions/index.js"
    },
    "./tempo/zones": {
      "src": "./src/tempo/zones/index.ts",
      "types": "./dist/tempo/zones/index.d.ts",
      "default": "./dist/tempo/zones/index.js"
    },
    "./tokens": {
      "src": "./src/tokens/index.ts",
      "types": "./dist/tokens/index.d.ts",
      "default": "./dist/tokens/index.js"
    },
    "./utils": {
      "src": "./src/utils/index.ts",
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    },
    "./window": {
      "src": "./src/window/index.ts",
      "types": "./dist/window/index.d.ts",
      "default": "./dist/window/index.js"
    },
    "./zod": {
      "src": "./src/zod/index.ts",
      "types": "./dist/zod/index.d.ts",
      "default": "./dist/zod/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "chains": [
        "./dist/chains/index.d.ts"
      ],
      "erc4337": [
        "./dist/erc4337/index.d.ts"
      ],
      "node": [
        "./dist/node/index.d.ts"
      ],
      "op-stack": [
        "./dist/op-stack/index.d.ts"
      ],
      "tempo": [
        "./dist/tempo/index.d.ts"
      ],
      "tempo/actions": [
        "./dist/tempo/actions/index.d.ts"
      ],
      "tempo/zones": [
        "./dist/tempo/zones/index.d.ts"
      ],
      "tokens": [
        "./dist/tokens/index.d.ts"
      ],
      "utils": [
        "./dist/utils/index.d.ts"
      ],
      "window": [
        "./dist/window/index.d.ts"
      ],
      "zod": [
        "./dist/zod/index.d.ts"
      ]
    }
  }
}
