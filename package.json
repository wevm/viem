  "[!start-pkg]": "",
  "name": "viem",
  "description": "TypeScript Interface for Ethereum",
  "version": "2.52.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "homepage": "https://viem.sh",
  "repository": {
    "type": "git",
