{
  // This file is used to emit the ESM package build. It should exclude all test files.
  "extends": "./tsconfig.base.json",
  "include": ["src"],
  "exclude": [
    "dist",
    "src/_cjs",
    "src/_esm",
    "src/_types",
    "src/**/*.test.ts",
    "src/**/*.test-d.ts",
    "src/node/trustedSetups_esm.ts"
  ],
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "incremental": false,
    "noEmit": false,
    "sourceMap": true,
    "rootDir": "./src"
  }
}
